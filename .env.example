# Copia este archivo a .env y rellena tus propias credenciales.
# Ninguno de los valores de aquí es un secreto real.

# --- APIs externas por dominio ---
RAWG_API_KEY=
TMDB_API_READ_ACCESS_TOKEN=

# --- Base de datos ---
# Ruta al archivo SQLite. Si se omite, usa data/swayp.db en la raíz del repo.
DATABASE_PATH=

# --- Logging (ver src/core/logging_config.py) ---
# Nivel mínimo de log: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
# Directorio donde se escribe el log rotado. Si se omite, usa logs/ en la raíz del repo.
LOG_DIR=
# Frecuencia de rotación del archivo de log: hourly | daily | weekly
LOG_ROTATION_INTERVAL=daily
# Nº de archivos rotados a conservar antes de borrar los más antiguos
LOG_RETENTION_COUNT=14
